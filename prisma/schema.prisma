generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  createdAt  DateTime   @default(now())
  categories Category[]
}

model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
